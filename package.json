{
  "name": "os.tech",
  "version": "2.3.5",
  "description": "Sistema de Gestão para Assistência Técnica de Computadores",
  "main": "dist/main/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force",
    "db:setup": "prisma generate && prisma migrate dev --name init && tsx prisma/seed.ts",
    "electron:dev": "electron-vite dev",
    "electron:build": "prisma generate && node scripts/init-db.js && npm run build && electron-vite build",
    "electron:dist": "npm run electron:build && electron-builder",
    "electron:dist:win": "npm run electron:build && electron-builder --win",
    "electron:dist:mac": "npm run electron:build && electron-builder --mac",
    "electron:dist:linux": "npm run electron:build && electron-builder --linux",
    "dist": "npm run electron:dist:win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@types/nodemailer": "^8.0.1",
    "imapflow": "^1.4.3",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "@prisma/client": "^6.19.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.7.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
